# Bungie API credentials — copy this file to `.env.local` (untracked) and fill in.
# Register an app at https://www.bungie.net/en/Application to obtain these.

# Required for Phase 0 Manifest ingestion (`pnpm ingest`).
# Sent as the `X-API-Key` header on Bungie API requests.
BUNGIE_API_KEY=

# Required later for Phase 2 OAuth ("what I own" toggle). Not used in Phase 0.
# Redirect URL registered with Bungie must be https://127.0.0.1:3000/api/auth/callback
# (Bungie rejects `localhost` and plain http; run the dev server via `pnpm dev:https`).
# BUNGIE_CLIENT_ID=
# BUNGIE_CLIENT_SECRET=
